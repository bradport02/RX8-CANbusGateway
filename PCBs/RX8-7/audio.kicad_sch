	(text "L (2h2 = 2.2µH inductor) in series with speaker positive\n	- Suppresses RF oscillation and EMI\n	- Good practice for car audio (lots of electrical noise)\n	- or 10uH?\nR (10Ω) + C (100nF) Zobel network parallel with speaker\n	- Provides high-frequency damping\n	- Improves stability with inductive speaker loads\n	- Prevents oscillation\n	- 2W Rated Resistors\nDirect connection from TDA7388 output to this network\n	- No bootstrap caps needed (as per datasheet)\n	- No series output resistors needed"
		(exclude_from_sim no)
		(at 186.436 145.288 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2e442a25-e7a7-4364-8a1d-b3f0c527e148")
	)
	(text "Capacitors block DC, allow AC\n(Cleaner Audio)"
